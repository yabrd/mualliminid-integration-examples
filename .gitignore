# Root-level safety gitignore for the monorepo

# Env files (semua level)
.env
.env.*
!**/.env.example

# Private keys
**/keys/*.pem
**/keys/*.key

# Laravel dependencies
**/vendor/

# Node dependencies & build output
**/node_modules/
**/dist/
**/dist-ssr/
**/public/build/
**/public/hot/
**/public/storage/

# Logs
*.log
**/storage/logs/*.log

# Editor & OS
.DS_Store
Thumbs.db
.vscode/
.idea/
.cursor/
.phpunit.cache/
.phpunit.result.cache
